# =============================================================
# DeepCache Replication - Environment Variables
# =============================================================
# Copy this file to .env and fill in the values below.
# NOTE: The default model (stable-diffusion-v1-5/stable-diffusion-v1-5)
#       is NOT gated, so HF_TOKEN is optional for the default setup.
#       Only needed if you use a gated model variant.

# Hugging Face Token (OPTIONAL for default model, needed for gated models)
# Get yours at: https://huggingface.co/settings/tokens
# 1. Go to https://huggingface.co/settings/tokens
# 2. Click "New token" -> name it anything -> Role: "Read"
# 3. Copy the token (starts with hf_...)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
